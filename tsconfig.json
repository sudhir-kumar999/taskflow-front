{
    "compilerOptions": {
        "target":"ES6",
        "module": "NodeNext",
        "jsx": "react-jsx",
        "strict": true,
        "moduleResolution": "nodenext",
        "allowSyntheticDefaultImports": true,
        "allowImportingTsExtensions": true,
        "noUncheckedSideEffectImports": false,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "types": ["node"]
    }
  },
    "include": ["src/**/*","webpack.config.js","index.d.ts"]
}